# Discord user token (not a bot token).
TOKEN=

# Guild (server) ID to monitor for join requests.
GUILD_ID=

# Channel ID to post notifications in.
CHANNEL_ID=

# Optional. Comma-separated user IDs allowed to approve/reject via y/n reply.
MODERATOR_MEMBERS=

# Optional. Comma-separated role IDs allowed to approve/reject via y/n reply.
MODERATOR_ROLES=

# Note: If both MODERATOR_MEMBERS and MODERATOR_ROLES are empty, anyone can
# approve/reject. Otherwise, access is granted if the author matches either list.
